{
   "$schema": "https://docs.renovatebot.com/renovate-schema.json",
   "extends": [
      "config:recommended"
   ],
   "labels": [
      "dependencies"
   ],
   "postUpdateOptions": [
      "gomodTidy"
   ],
   "ignorePaths": [
      "cova/.copier-answers.yml"
   ],
   "customManagers": [
      {
         "customType": "regex",
         "description": "Update go install version pins in CI workflows",
         "fileMatch": [
            "^\\.github/workflows/.*\\.yml$"
         ],
         "matchStrings": [
            "go install (?<depName>[^@]+)@v(?<currentValue>\\S+)"
         ],
         "datasourceTemplate": "go"
      }
   ]
}
